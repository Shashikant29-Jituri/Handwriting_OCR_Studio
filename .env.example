# Copy this file to .env and fill in the keys for whichever providers you want to use.
# You do NOT need all of them -- just the one(s) matching the models you pick in the sidebar.

# --- Vision / OCR model providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Cloud save (optional) ---
# Google Drive: create OAuth 2.0 Client ID (Desktop app) in Google Cloud Console,
# download the JSON, and point this at its path.
GOOGLE_OAUTH_CLIENT_SECRET_FILE=client_secret.json

# Dropbox: create an app at https://www.dropbox.com/developers/apps
# and generate a long-lived / refreshable access token.
DROPBOX_ACCESS_TOKEN=
